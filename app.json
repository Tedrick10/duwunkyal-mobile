{
  "expo": {
    "name": "DUWUN KYAL",
    "slug": "duwunkyal",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/logo-white-bg.png",
    "scheme": "duwunkyal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo-white-bg.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nebwintech.duwunkyal",
      "googleServicesFile": "./GoogleService-Info.plist",
      "deploymentTarget": "16.6",
      "infoPlist": {
        "UIRequiresFullScreen": true
      },
      "appleTeamId": "FH4F75KHBD"
    },
    "android": {
      "package": "com.nebwintech.duwunkyal",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/logo-white-bg.png"
      },
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/logo-white-bg.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.6",
            "buildReactNativeFromSource": true
          }
        }
      ],
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Allow Duwunkyal to save your custom designs to the photo gallery."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo-white-bg.png",
          "color": "#ffffff",
          "sounds": [],
          "androidMode": "default",
          "iosDisplayInForeground": true
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./plugins/withFirebaseFixes.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "cfd1770c-6d24-44ac-8682-0711e2bd57c5"
      }
    }
  }
}
