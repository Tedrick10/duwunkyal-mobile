# Backend API base URL (no trailing slash)
# Postman uses your computer → backend works. Mobile uses phone/simulator → URL must match.

# Option A: Physical device (real phone) – use your computer's LAN IP
# Find IP: Mac/Linux: ifconfig | grep "inet "  |  Windows: ipconfig
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.2:8000

# Option B: Simulator/Emulator only (backend on same machine)
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Backend must listen on all interfaces for physical device:
#   php artisan serve --host=0.0.0.0

# Segment API (Clothing Segments at port 8003) for Customize Front/Back View region detection.
# Default: derived from API base (port 8003). Override if segment service runs elsewhere.
# EXPO_PUBLIC_SEGMENT_API_URL=http://192.168.1.2:8003
